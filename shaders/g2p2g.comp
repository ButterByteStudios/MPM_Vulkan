#extension GL_EXT_shader_atomic_float: enable
#extension GL_ARB_shading_language_include: enable
#include "global.glsl"

#define BIN_COUNT (16)

struct WorkgroupData
{
	ivec2 blockCoords;
	uint firstBinIndex;
	uint binCount;
};

layout(std430, binding = BIND_VR) readonly buffer GridVelocitySSBOIn
